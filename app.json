{
  "expo": {
    "name": "ShotgunBlackbox",
    "slug": "ShotgunBlackbox",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow ShotgunBlackbox to use your location for live ride speed, route and dashboard data."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Allow ShotgunBlackbox to read device motion for live motorcycle lean angle."
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
